# Secrets para las Edge Functions de Supabase.
# Cuando uses `supabase functions serve`, este archivo se carga vía:
#   supabase functions serve --env-file ./.env --workdir backend
#
# En producción, configura estos secrets con:
#   supabase secrets set OPENAI_API_KEY=sk-... --workdir backend
OPENAI_API_KEY=sk-proj-replace-with-your-real-key
