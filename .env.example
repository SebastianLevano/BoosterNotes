# ===== Cliente Expo (app/) =====
# Estas variables se inyectan en el bundle del cliente. NUNCA pongas la API key
# de OpenAI aquí — se extraería del binario.
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...replace-with-anon-key

# ===== Backend Supabase (backend/.env) =====
# Estas viven en el servidor; se cargan a la edge function como secrets.
# NO se incluyen en el cliente.
OPENAI_API_KEY=sk-proj-replace-with-your-real-key
